    "body_html": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"color-scheme\" content=\"light dark\">\n<meta name=\"supported-color-schemes\" content=\"light dark\">\n<title>Yeni Etkinlik Planlandı</title>\n\n<style>\n  @media (prefers-color-scheme: dark) {\n    body { background-color:#000000 !important; }\n    .container { background-color:#1c1c1e !important; }\n    .text { color:#ffffff !important; }\n    .subtext { color:#a1a1a6 !important; }\n    .box { background-color:#2c2c2e !important; }\n    .divider { background-color:#3a3a3c !important; }\n  }\n</style>\n</head>\n\n<body style=\"margin:0; padding:0; background:#f5f5f7; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\">\n\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding:40px 0;\">\n<tr>\n<td align=\"center\">\n\n<table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" class=\"container\" style=\"background:#ffffff; border-radius:18px; overflow:hidden; box-shadow:0 10px 40px rgba(0,0,0,0.06);\">\n\n  <!-- TITLE -->\n  <tr>\n    <td style=\"padding:40px 40px 20px 40px; text-align:center;\">\n      <h1 class=\"text\" style=\"margin:0; font-size:24px; font-weight:600; color:#1d1d1f;\">\n        Yeni Etkinlik Planlandı 📅\n      </h1>\n      <p class=\"subtext\" style=\"margin-top:10px; font-size:15px; color:#6e6e73;\">\n        Takviminize eklemeniz gereken yeni bir plan oluşturuldu.\n      </p>\n    </td>\n  </tr>\n\n  <!-- DIVIDER -->\n  <tr>\n    <td style=\"padding:0 40px;\">\n      <div class=\"divider\" style=\"height:1px; background:#e5e5e7;\"></div>\n    </td>\n  </tr>\n\n  <!-- CONTENT -->\n  <tr>\n    <td style=\"padding:30px 40px;\" class=\"text\">\n\n      <p>Merhaba <strong>{{client_name}}</strong>,</p>\n\n      <p>\n        Sizin için yeni bir etkinlik planlandı. Detaylar aşağıda yer almaktadır:\n      </p>\n\n      <!-- EVENT INFO -->\n      <div class=\"box\" style=\"background:#f5f