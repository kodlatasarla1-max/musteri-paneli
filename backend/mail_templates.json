    "template_type": "welcome",
    "subject": "Mova Dijital’e Hoş Geldiniz",
    "body_html": "<!DOCTYPE html>\n<html lang=\"tr\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Mova Dijital'e Hoş Geldiniz</title>\n</head>\n<body style=\"margin:0; padding:0; background-color:#f5f5f7; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\">\n\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#f5f5f7; padding:40px 0;\">\n    <tr>\n      <td align=\"center\">\n\n        <!-- Container -->\n        <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff; border-radius:16px; overflow:hidden; box-shadow:0 10px 30px rgba(0,0,0,0.05);\">\n\n          <!-- Header -->\n          <tr>\n            <td style=\"padding:40px 40px 20px 40px; text-align:center;\">\n              <h1 style=\"margin:0; font-size:28px; font-weight:600; color:#1d1d1f;\">\n                Mova Dijital’e Hoş Geldiniz\n              </h1>\n              <p style=\"margin-top:10px; font-size:16px; color:#6e6e73;\">\n                Paneliniz hazır. Tüm süreci buradan yöneteceksiniz.\n              </p>\n            </td>\n          </tr>\n\n          <!-- Divider -->\n          <tr>\n            <td style=\"padding:0 40px;\">\n              <div style=\"height:1px; background:#e5e5e7;\"></div>\n            </td>\n          </tr>\n\n          <!-- Content -->\n          <tr>\n            <td style=\"padding:30px 40px; color:#1d1d1f; font-size:15px; line-height:1.6;\">\n              \n              <p>Merhaba <strong>{{client_name}}</strong>,</p>\n\n              <p>\n                Sizin için oluşturduğumuz müşteri paneliniz aktif. Artık tüm süreçlerinizi tek bir yerden hızlı ve şeffaf şekilde yönetebilirsiniz.\n              </p>\n\n              <!-- Features -->\n              <ul style=\"padding-left:18px; margin:20px 0; color:#3a3a3c;\">\n                <li>İçeriklerinizi görüntüleme ve onaylama</li>\n                <li>Revizyon talepleri oluşturma</li>\n                <li>Reklam performansını takip etme</li>\n                <li>Makbuz yükleme</li>\n                <li>Planlanan çalışmaları görüntüleme</li>\n              </ul>\n\n              <!-- CTA -->\n              <div style=\"text-align:center; margin:30px 0;\">\n                <a href=\"{{login_url}}\" \n                   style=\"background:#0071e3; color:#ffffff; text-decoration:none; padding:14px 28px; border-radius:10px; font-size:15px; font-weight:500; display:inline-block;\">\n                   Paneline Giriş Yap\n                </a>\n              </div>\n\n              <!-- Login Info -->\n              <div style=\"background:#f5f5f7; padding:20px; border-radius:12px; font-size:14px;\">\n                <p style=\"margin:0;\"><strong>E-posta:</strong> {{email}}</p>\n                <p style=\"margin:5px 0 0 0;\"><strong>Şifre:</strong> {{password}}</p>\n                <p style=\"margin:10px 0 0 0;\"><strong>Erişim Süresi:</strong> {{expiry_date}}</p>\n              </div>\n\n              <p style=\"margin-top:25px;\">\n                Herhangi bir sorunuz olursa bu e-posta üzerinden bizimle iletişime geçebilirsiniz.\n              </p>\n\n              <p style=\"margin-top:10px;\">\n                Başarılı bir süreç için birlikte çalışıyoruz.\n              </p>\n\n            </td>\n          </tr>\n\n          <!-- Footer -->\n          <tr>\n            <td style=\"padding:25px 40px; text-align:center; font-size:13px; color:#8e8e93;\">\n              Mova Dijital<br>\n              Tüm hakları saklıdır.\n            </td>\n          </tr>\n\n        </table>\n\n        <!-- Bottom spacing -->\n        <div style=\"height:40px;\"></div>\n\n      </td>\n    </tr>\n  </table>\n\n</body>\n</html>"
